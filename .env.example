# Server Configuration
# The port the router will listen on
ROUTER_SERVER_PORT=:8080

# The timeout for the server
ROUTER_SERVER_TIMEOUT=5s

# Cluster Configuration
# A comma-separated list of backend node URLs
ROUTER_CLUSTER_NODES=http://localhost:8081,http://localhost:8082,http://localhost:8083

ROUTER_CLUSTER_MAX_CONCURRENCY=100

# DEBUG | INFO | WARN | ERROR
ROUTER_LOG_LEVEL=ERROR
NODE_LOG_LEVEL=ERROR
