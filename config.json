{
  "server": {
    "port": ":8080",
    "timeout": "5s"
  },
  "cluster": {
    "nodes": [
      "http://localhost:8081",
      "http://localhost:8082",
      "http://localhost:8083"
    ],
    "max_concurrency": 100
  },
  "http_client": {
    "max_idle_conns": 100,
    "max_idle_conns_per_host": 100,
    "max_conns_per_host": 100,
    "idle_conn_timeout": "90s"
  }
}
